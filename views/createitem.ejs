<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Product</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">

    <form action="/products/createitem" method="POST" enctype="multipart/form-data" class="bg-white shadow-lg rounded-lg p-8 w-full max-w-md flex flex-col gap-5">
        <h2 class="text-2xl font-bold text-gray-800 text-center mb-4">Add New Product</h2>

        <input type="text" name="name" placeholder="Product Name" required
            class="p-3 rounded-md border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition">

        <input type="text" name="description" placeholder="Description"
            class="p-3 rounded-md border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition">

        <input type="text" name="category" placeholder="Category" required
            class="p-3 rounded-md border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition">

        <input type="number" name="price" placeholder="Price" required
            class="p-3 rounded-md border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition">

        <input type="file" name="image" accept="image/*" required
            class="p-2 rounded-md border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition">

        <button type="submit"
            class="bg-blue-600 text-white py-3 rounded-md font-semibold hover:bg-blue-700 transition shadow-md hover:shadow-lg">
            Create Product
        </button>
    </form>

</body>
</html>
