<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home Page</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script><!DOCTYPE html>

<body class="bg-gray-100">

  <!-- Navbar -->
  <nav class="flex justify-between items-center p-4 bg-blue-600 text-white">
    <div class="text-xl font-bold">MyShop</div>
    
    <div class="flex items-center space-x-4">
      
      <%if(typeof seller !== "undefined" && seller ){%>
         <a href="/createitem" class="bg-yellow-500 px-3 py-1 rounded">new Product</a>
         <span class="border-[2px] border-black w-[fit] rounded-md px-2 h-[30px]"><%= seller.shopname %></span>
         <a href="/logout" class="bg-red-500 px-3 py-1 rounded">Logout</a>

      <%} else if (typeof User !== "undefined" && User) { %>
        
        <img src="" alt="User Image" class="w-10 h-10 rounded-full border-2 border-white">
        <span><%= User.username %></span>
        <a href="/logout" class="bg-red-500 px-3 py-1 rounded">Logout</a>
      <% } else { %>
        <a href="/signup" class="bg-green-500 px-3 py-1 rounded">Signup</a>
        <a href="/login" class="bg-yellow-500 px-3 py-1 rounded">Login</a>
      <% } %>
    </div>
  </nav>

  <!-- Items Section -->
  <div class="container mx-auto mt-8">
    <h2 class="text-2xl font-bold mb-4">Available Items</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
      <% itemsarray.forEach(item => { %>
        <a href="/itempreview/<%=item.id%>">
        <div class="rounded flex flex-col justify-end p-1 bg-[url(<%=item.image%>)] bg-cover bg-center shadow h-[450px] w-[300px]">
          <!-- <img src=  class="w-full h-full object-cover rounded mb-3"> -->
          <div class=" p-2 bg-black/30 border-b-2 border-r-2 border-gray-400  backdrop-blur-[15px] rounded-xl">
          <h3 class="text-lg font-semibold text-white"><%= item.name %></h3>
          <p class="text-gray-300 "><%= item.description %></p>
          <p class="text-blue-600 font-bold mt-2">₹<%= item.price %></p>
          </div>
        </div>
        </a>
      <% }) %>
    </div>
  </div>

</body>
</html>
